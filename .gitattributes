# Auto detect text files and ensure LF in repo
* text=auto eol=lf

# Source code
*.js    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.jsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf

# Scripts
*.sh    text eol=lf
*.py    text eol=lf
*.ps1   text eol=lf
*.bat   text eol=crlf
*.vbs   text eol=crlf

# Config / Data
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf

# C/C++
*.c     text eol=lf
*.h     text eol=lf

# Git
.gitattributes text eol=lf
.gitignore     text eol=lf

# Binary (no conversion)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pptx  binary
*.docx  binary
*.xlsx  binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
