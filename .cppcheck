<?xml version="1.0" encoding="UTF-8"?>
<!--
  Cppcheck project settings for TORASAN
  Target: Renesas RL78/G14, IEC 60730 Class B
  Usage: cppcheck --project=.cppcheck src/
-->
<project version="1">
  <paths>
    <dir name="src/"/>
  </paths>
  <excludes>
    <path name="src/archive_v1/"/>
  </excludes>
  <platform>platforms/rl78g14.xml</platform>
  <libraries>
  </libraries>
  <suppressions>
    <suppress>
      <id>missingIncludeSystem</id>
    </suppress>
  </suppressions>
  <check-headers>yes</check-headers>
  <check-unused-templates>yes</check-unused-templates>
  <max-ctu-depth>2</max-ctu-depth>
  <check-level>exhaustive</check-level>
</project>
